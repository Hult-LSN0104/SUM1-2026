def summarize_customers(customers):
    """
    Print a summary line for every customer showing:
    ID, name, email, tier, total spent, and average purchase.

    Uses dict.items() to iterate over customer IDs and profiles together.

    Args:
        customers (dict): Mapping of customer_id -> customer profile dict.
    """
    print(f"\n  {'ID':<6} {'NAME':<18} {'EMAIL':<28} {'TIER':<8} {'TOTAL':>10} {'AVG':>10}")
    print("  " + "-" * 82)

    # .items() gives us both the key (customer_id) and value (profile) at once
    for cid, profile in customers.items():
        total   = sum(profile["purchases"])
        average = total / len(profile["purchases"]) if profile["purchases"] else 0.0
        print(
            f"  {cid:<6} {profile['name']:<18} {profile['email']:<28}"
            f" {profile['tier']:<8} {total:>10.2f} {average:>10.2f}"
        )


def find_top_customer(customers):
    """
    Return the customer ID (key) of the customer with the highest total spending.
    Uses dict.items() to access both ID and profile for comparison.

    Args:
        customers (dict): Mapping of customer_id -> customer profile dict.

    Returns:
        str: The customer ID with the greatest total purchases.
    """
    # .items() lets us compare totals while keeping track of which ID they belong to
    top_id = max(
        customers.items(),
        key=lambda kv: sum(kv[1]["purchases"])
    )[0]
    return top_id


def upgrade_to_gold(customers):
    """
    Upgrade any customer whose total spending exceeds $5,000 to 'Gold' tier.
    Uses dict.keys() to iterate over customer IDs and look up each profile.

    Args:
        customers (dict): Mapping of customer_id -> customer profile dict.
                          Modified in-place.
    """
    upgraded = []

    # .keys() gives us the IDs; we then index into the dict for the profile
    for cid in customers.keys():
        profile = customers[cid]
        if sum(profile["purchases"]) > 5000:
            profile["tier"] = "Gold"
            upgraded.append(profile["name"])

    if upgraded:
        print(f"  ✓ Upgraded to Gold: {', '.join(upgraded)}")
    else:
        print("  No customers qualify for Gold tier at this time.")


