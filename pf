inventory = [
    {"name": "Widget Pro",   "sku": "WP-001", "quantity": 25, "unit_price": 19.99},
    {"name": "Gadget Plus",  "sku": "GP-002", "quantity": 10, "unit_price": 49.99},
    {"name": "Thingamajig", "sku": "TJ-003", "quantity": 50, "unit_price":  4.99},
]


def view_items(items):
    """
    Print every item in the inventory in a readable, tabular format.

    Args:
        items (list[dict]): The inventory list.
    """
    if not items:
        print("  (inventory is empty)")
        return

    # Column widths for clean alignment
    print(f"\n  {'NAME':<20} {'SKU':<10} {'QTY':>6} {'UNIT PRICE':>12} {'LINE VALUE':>12}")
    print("  " + "-" * 64)
    for item in items:
        line_value = item["quantity"] * item["unit_price"]
        print(
            f"  {item['name']:<20} {item['sku']:<10}"
            f" {item['quantity']:>6} {item['unit_price']:>12.2f} {line_value:>12.2f}"
        )


def add_item(items):
    """
    Prompt the user for name, SKU, quantity, and unit_price,
    then append a new dict to items.

    Args:
        items (list[dict]): The inventory list (modified in-place).
    """
    print("\n  -- Add New Item --")
    name = input("  Name: ").strip()
    sku  = input("  SKU:  ").strip()

    # Validate quantity — must be a non-negative integer
    while True:
        try:
            quantity = int(input("  Quantity: ").strip())
            if quantity < 0:
                raise ValueError
            break
        except ValueError:
            print("  ✗ Please enter a non-negative whole number.")

    # Validate unit_price — must be a non-negative float
    while True:
        try:
            unit_price = float(input("  Unit Price: ").strip())
            if unit_price < 0:
                raise ValueError
            break
        except ValueError:
            print("  ✗ Please enter a non-negative number (e.g. 9.99).")

    items.append({"name": name, "sku": sku, "quantity": quantity, "unit_price": unit_price})
    print(f"  ✓ '{name}' added to inventory.")


def remove_item(items, sku):
    """
    Remove the item whose SKU matches (case-insensitive).
    Print a message if the SKU is not found.

    Args:
        items (list[dict]): The inventory list (modified in-place).
        sku   (str):        SKU to remove.
    """
    sku = sku.strip().upper()
    for item in items:
        if item["sku"].upper() == sku:
            items.remove(item)
            print(f"  ✓ Item '{item['name']}' (SKU: {sku}) removed.")
            return
    print(f"  ✗ SKU '{sku}' not found in inventory.")


def update_quantity(items, sku, new_quantity):
    """
    Update the quantity for the item with the given SKU.
    Print a message if the SKU is not found.

    Args:
        items        (list[dict]): The inventory list (modified in-place).
        sku          (str):        SKU to look up.
        new_quantity (int):        Replacement quantity value.
    """
    sku = sku.strip().upper()
    for item in items:
        if item["sku"].upper() == sku:
            old_qty = item["quantity"]
            item["quantity"] = new_quantity
            print(f"  ✓ '{item['name']}': quantity updated {old_qty} → {new_quantity}.")
            return
    print(f"  ✗ SKU '{sku}' not found in inventory.")


def total_value(items):
    """
    Return the total monetary value of the inventory
    as the sum of (quantity * unit_price) for every item.

    Args:
        items (list[dict]): The inventory list.

    Returns:
        float: Total inventory value.
    """
    return sum(item["quantity"] * item["unit_price"] for item in items)


def inventory_menu():
    """
    Run the Inventory Manager menu loop.
    Presents options 1–6 and dispatches to the appropriate function.
    Exits when the user selects option 6.
    """
    while True:
        print("\n===== INVENTORY MANAGER =====")
        print("1. View all items")
        print("2. Add new item")
        print("3. Remove item by SKU")
        print("4. Update quantity by SKU")
        print("5. Show total inventory value")
        print("6. Exit")
        choice = input("Choice: ").strip()

        if choice == "1":
            view_items(inventory)

        elif choice == "2":
            add_item(inventory)

        elif choice == "3":
            sku = input("  Enter SKU to remove: ").strip()
            remove_item(inventory, sku)

        elif choice == "4":
            sku = input("  Enter SKU to update: ").strip()
            while True:
                try:
                    qty = int(input("  New quantity: ").strip())
                    if qty < 0:
                        raise ValueError
                    break
                except ValueError:
                    print("  ✗ Please enter a non-negative whole number.")
            update_quantity(inventory, sku, qty)

        elif choice == "5":
            value = total_value(inventory)
            print(f"  Total inventory value: ${value:,.2f}")

        elif choice == "6":
            print("Goodbye!")
            break

        else:
            # Invalid input — no crash, just an informative message
            print("  ✗ Invalid choice. Please enter a number from 1 to 6.")


