CSV_PATH    = "sales_data.csv"
REPORT_PATH = "sales_report.txt"


# ---- Part A — Read and Parse (10 pts) ---------------------------------------

def load_sales(path):
    """
    Read the CSV at `path` using csv.DictReader.

    Performs type conversions on each row:
        - quantity   -> int
        - unit_price -> float
        - revenue    -> float  (added field: quantity * unit_price)

    Args:
        path (str): File path to the CSV file.

    Returns:
        list[dict]: A list of row dicts with converted/added fields.

    Raises:
        FileNotFoundError: If `path` does not exist.
    """
    records = []

    # newline="" is required by the csv module to avoid cross-platform issues
    with open(path, newline="", encoding="utf-8") as fh:
        reader = csv.DictReader(fh)
        for row in reader:
            row["quantity"]   = int(row["quantity"])
            row["unit_price"] = float(row["unit_price"])
            row["revenue"]    = row["quantity"] * row["unit_price"]  # derived field
            records.append(row)

    return records


# ---- Part B — Analyze (10 pts) ----------------------------------------------

def analyze_sales(records):
    """
    Compute summary statistics from a list of sale records.

    Args:
        records (list[dict]): Sales records as returned by load_sales().

    Returns:
        dict with keys:
            total_revenue    (float)
            average_revenue  (float)  – per transaction
            top_rep          (dict)   – {"name": str, "revenue": float}
            revenue_by_region(dict)   – {region: float, ...}
            best_product     (dict)   – {"name": str, "units_sold": int}
    """
    if not records:
        return {}

    # --- total and average revenue ---
    total_revenue   = sum(r["revenue"] for r in records)
    average_revenue = total_revenue / len(records)

    # --- revenue per rep ---
    rep_revenue = {}
    for r in records:
        rep_revenue[r["rep_name"]] = rep_revenue.get(r["rep_name"], 0.0) + r["revenue"]

    top_rep_name = max(rep_revenue, key=rep_revenue.get)
    top_rep      = {"name": top_rep_name, "revenue": rep_revenue[top_rep_name]}

    # --- revenue by region ---
    revenue_by_region = {}
    for r in records:
        revenue_by_region[r["region"]] = (
            revenue_by_region.get(r["region"], 0.0) + r["revenue"]
        )

    # --- best product by units sold ---
    product_units = {}
    for r in records:
        product_units[r["product"]] = product_units.get(r["product"], 0) + r["quantity"]

    best_product_name = max(product_units, key=product_units.get)
    best_product      = {"name": best_product_name, "units_sold": product_units[best_product_name]}

    return {
        "total_revenue":     total_revenue,
        "average_revenue":   average_revenue,
        "top_rep":           top_rep,
        "revenue_by_region": revenue_by_region,
        "best_product":      best_product,
    }


# ---- Part C — Write Report (10 pts) -----------------------------------------

def write_report(stats, path):
    """
    Write a formatted, human-readable sales report to `path`.

    Report sections:
        1. Overview       — total revenue, average per transaction
        2. Top Rep        — name and revenue
        3. Revenue by Region — aligned columns
        4. Best Product   — name and units sold
        5. Generated timestamp

    Args:
        stats (dict): Statistics dict as returned by analyze_sales().
        path  (str):  File path to write the report to.
    """
    timestamp = datetime.now().strftime("%Y-%m-%d %H:%M:%S")
    sep_major = "=" * 52
    sep_minor = "-" * 52

    with open(path, "w", encoding="utf-8") as fh:

        # ----- Header -----
        fh.write(sep_major + "\n")
        fh.write("         SALES PERFORMANCE REPORT\n")
        fh.write(sep_major + "\n")
        fh.write(f"  Generated: {timestamp}\n\n")

        # ----- Section 1: Overview -----
        fh.write("OVERVIEW\n")
        fh.write(sep_minor + "\n")
        fh.write(f"  {'Total Revenue:':<28} ${stats['total_revenue']:>10,.2f}\n")
        fh.write(f"  {'Avg Revenue per Transaction:':<28} ${stats['average_revenue']:>10,.2f}\n\n")

        # ----- Section 2: Top Sales Rep -----
        fh.write("TOP SALES REPRESENTATIVE\n")
        fh.write(sep_minor + "\n")
        rep = stats["top_rep"]
        fh.write(f"  {'Name:':<28} {rep['name']}\n")
        fh.write(f"  {'Revenue:':<28} ${rep['revenue']:>10,.2f}\n\n")

        # ----- Section 3: Revenue by Region -----
        fh.write("REVENUE BY REGION\n")
        fh.write(sep_minor + "\n")
        for region, rev in sorted(stats["revenue_by_region"].items()):
            fh.write(f"  {region:<28} ${rev:>10,.2f}\n")
        fh.write("\n")

        # ----- Section 4: Best Product -----
        fh.write("BEST-SELLING PRODUCT\n")
        fh.write(sep_minor + "\n")
        prod = stats["best_product"]
        fh.write(f"  {'Product:':<28} {prod['name']}\n")
        fh.write(f"  {'Units Sold:':<28} {prod['units_sold']:>10,}\n\n")

        # ----- Footer -----
        fh.write(sep_major + "\n")
        fh.write("                  END OF REPORT\n")
        fh.write(sep_major + "\n")


